# ─────────────────────────────────────────────────────────────
# Aithreus Unified CMS — environment template
# Copy to `.env` and fill in. Never commit `.env`.
# See specs/00-product/01-architecture.md §6.
# ─────────────────────────────────────────────────────────────

# Postgres is DEFERRED (specs §01 D4). When DATABASE_URL is UNSET the app
# runs on the in-memory store (seeded at boot). Set it in Phase 7 to switch
# to AWS RDS Postgres (eu-west-1) with zero UI changes.
# DATABASE_URL=postgres://user:pass@<rds-endpoint>.eu-west-1.rds.amazonaws.com/aithreus

# Auth.js — required. Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-32-byte-base64-secret

# App + widget URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
# prod: https://cdn.aithreus.com/widget/v1/embed.js
NEXT_PUBLIC_WIDGET_CDN_URL=http://localhost:3000/widget/v1/embed.js

# Runtime config cache TTL (seconds); busted on Publish
CONFIG_CACHE_TTL_SECONDS=60

# AWS
AWS_REGION=eu-west-1

# Optional production analytics seam (UNUSED in prototype — Postgres rollups instead)
# CLICKHOUSE_URL=
